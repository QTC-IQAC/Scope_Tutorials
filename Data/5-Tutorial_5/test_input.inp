
&environment
   max_jobs         = 80
   max_procs        = 240
   requested_procs  = 8
   queue            = 'my_preferred_one'
/

&options
/

&job_data
   branch       = 'Isolated'
   workflow     = ['reference']
   job_setup    = 'regular'
   suffix       = 'opt'
   keyword      = 'pbe opt'

   istate       = 'initial'
   fstate       = 'pbe opt'

   hierarchy    = 1
   requisites   = []
   constrains   = ['self']
   must_be_good = False
/

&qc_data
   software     = 'g16'
   jobtype      = 'opt'
   functional   = 'pbe'
   basis        = 'def2SVP'
   is_grimme    = True
   loose_opt    = True
/